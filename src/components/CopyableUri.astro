---
interface Props {
	uri: string;
}
const { uri } = Astro.props;
---

<div class="uri-copy-row">
	<input class="uri-input" type="text" readonly value={uri} id="canonical-uri" />
	<button class="uri-copy-btn" type="button" id="copy-uri-btn" aria-label="Copy URI">
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
		<span id="copy-label">Copy</span>
	</button>
</div>

<style>
	.uri-copy-row {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		width: 100%;
	}
	.uri-input {
		flex: 1;
		font-family: var(--sl-font-mono, monospace);
		font-size: 0.875rem;
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--sl-color-gray-5, #ccc);
		border-radius: 0.375rem;
		background: var(--sl-color-black, #fff);
		color: var(--sl-color-white, #111);
		min-width: 0;
		cursor: text;
	}
	.uri-copy-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.5rem 0.875rem;
		border: 1px solid var(--sl-color-gray-5, #ccc);
		border-radius: 0.375rem;
		background: var(--sl-color-gray-6, #f4f4f4);
		color: var(--sl-color-gray-1, #333);
		font-size: 0.875rem;
		cursor: pointer;
		white-space: nowrap;
		transition: background 0.15s, border-color 0.15s;
	}
	.uri-copy-btn:hover {
		background: var(--sl-color-gray-5, #e4e4e4);
		border-color: var(--sl-color-gray-4, #aaa);
	}
	.uri-copy-btn.copied {
		background: var(--sl-color-gray-5, #e4e4e4);
		border-color: var(--sl-color-gray-4, #aaa);
	}
</style>

<script>
	const btn = document.getElementById('copy-uri-btn');
	const label = document.getElementById('copy-label');
	btn?.addEventListener('click', async () => {
		const input = document.getElementById('canonical-uri') as HTMLInputElement;
		await navigator.clipboard.writeText(input.value);
		if (label) label.textContent = 'Copied!';
		btn.classList.add('copied');
		setTimeout(() => {
			if (label) label.textContent = 'Copy';
			btn.classList.remove('copied');
		}, 2000);
	});
</script>
